# Terraform - never commit these
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfvars
!example.tfvars
crash.log

# AWS credentials - never commit
.aws/
*.pem
*.key

# SSH private keys - never commit
id_rsa
id_ed25519

# Python
__pycache__/
*.pyc
.env
venv/

# OS files
.DS_Store
Thumbs.db